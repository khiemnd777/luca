server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/promtail/positions.yaml

clients:
  - url: __LOKI_BASE_URL__/loki/api/v1/push

scrape_configs:
  - job_name: __SERVICE_NAME__
    static_configs:
      - targets:
          - localhost
        labels:
          job: __SERVICE_NAME__
          app: __SERVICE_NAME__
          source: app_stdout
          __path__: /var/log/noah/*.log
    pipeline_stages:
      - json:
          expressions:
            ts: ts
            level: level
            message: message
            service: service
            module: module
            env: env
            request_id: request_id
            user_id: user_id
            department_id: department_id
            source: source
            stacktrace: stacktrace
      - labels:
          level:
          service:
          module:
          env:
